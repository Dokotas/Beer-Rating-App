.row.justify-content-center
  .col-md-5
    %h2= t("users.sign_in")
    = form_with url: signin_path, scope: :session, local: true do |f|
      .mb-3
        = f.label :email, t("users.email"), class: "form-label"
        = f.email_field :email, class: "form-control"
      .mb-3
        = f.label :password, t("users.password"), class: "form-label"
        = f.password_field :password, class: "form-control"
      = f.submit t("users.sign_in"), class: "btn btn-primary"